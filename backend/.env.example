# ===============================
# NodeSight Backend Configuration
# ===============================

NODE_ENV=development

# WebSocket Gateway
GATEWAY_PORT=8080
WS_PUBLIC_URL=ws://localhost:8080

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_STREAM_NAME=nodesight_stream

# AI Worker
WORKER_CONCURRENCY=2
AI_MODEL=yolov8n.pt
USE_GPU=true

# Image Processing
MAX_IMAGE_SIZE=5242880
IMAGE_COMPRESSION_QUALITY=0.7
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Session
SESSION_TIMEOUT=300
WS_HEARTBEAT_INTERVAL=15000
WS_MAX_RECONNECTS=5

# Security
API_KEY=
JWT_SECRET=change_this_secret
ENABLE_RATE_LIMIT=true
RATE_LIMIT_RPM=100

# Logging
LOG_LEVEL=info
LOG_JSON=true

# Storage
ENABLE_IMAGE_STORAGE=false
STORAGE_PROVIDER=s3

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=nodesight-images-storage

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
