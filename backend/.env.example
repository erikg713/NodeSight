# ===============================
# NodeSight Backend Configuration
# ===============================

# Environment
NODE_ENV=development

# ===============================
# WebSocket Gateway
# ===============================

# Port used by the NodeSight WebSocket gateway
GATEWAY_PORT=8080

# Public WebSocket endpoint clients connect to
WS_PUBLIC_URL=ws://localhost:8080

# ===============================
# Redis Configuration
# ===============================

# Redis server hostname
REDIS_HOST=redis

# Redis server port
REDIS_PORT=6379

# Redis password (optional)
REDIS_PASSWORD=

# Redis stream name used for AI jobs
REDIS_STREAM_NAME=nodesight_stream

# ===============================
# AI Worker Configuration
# ===============================

# Worker concurrency (number of parallel jobs)
WORKER_CONCURRENCY=2

# Model used for object detection
AI_MODEL=yolov8n.pt

# Enable GPU acceleration
USE_GPU=true

# ===============================
# Image Processing
# ===============================

# Maximum image size allowed (bytes)
MAX_IMAGE_SIZE=5242880

# Compression quality (0.0 - 1.0)
IMAGE_COMPRESSION_QUALITY=0.7

# Allowed image types
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# ===============================
# Session / Streaming
# ===============================

# Session timeout in seconds
SESSION_TIMEOUT=300

# Heartbeat interval for WebSocket connections
WS_HEARTBEAT_INTERVAL=15000

# Maximum reconnection attempts
WS_MAX_RECONNECTS=5

# ===============================
# Security
# ===============================

# API key required to access NodeSight API
API_KEY=

# JWT secret for session authentication
JWT_SECRET=change_this_secret

# Enable request rate limiting
ENABLE_RATE_LIMIT=true

# Max requests per minute
RATE_LIMIT_RPM=100

# ===============================
# Logging
# ===============================

LOG_LEVEL=info

# Enable structured logs
LOG_JSON=true

# ===============================
# Storage (optional)
# ===============================

# Save uploaded images to storage
ENABLE_IMAGE_STORAGE=false

# Storage provider
# ==============================
 ```
 STORAGE_PROVIDER=s3
```
#==================================
# ===============================
# AWS S3 configuration
# ===============================
AWS_ACCESS_KEY_ID=AKIA2JKSJXJS8K3
AWS_SECRET_ACCESS_KEY=9fshhYg7sJHsdh82h2h2h2
AWS_REGION=us-east-1
AWS_S3_BUCKET=nodesight-images-storage

# ===============================
# Monitoring
# ===============================

# Enable metrics
ENABLE_METRICS=true

# Prometheus metrics endpoint
METRICS_PORT=9090

